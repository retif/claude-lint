[7.588239, "o", "\r\n\u001b[4mtests/fixtures/demo-plugin/.claude-plugin/plugin.json\u001b[24m\r\n  \u001b[31merror\u001b[39m  \"name\" must be kebab-case (got \"My Deploy Plugin\")  \u001b[2mplugin-json/name-kebab-case\u001b[22m\u001b[2m:2:2\u001b[22m\r\n  \u001b[33mwarn \u001b[39m  \"version\" should be valid semver (got \"1.0\")  \u001b[2mplugin-json/version-semver\u001b[22m\u001b[2m:3:2\u001b[22m\r\n\r\n\u001b[4mtests/fixtures/demo-plugin/skills/deploy/SKILL.md\u001b[24m\r\n  \u001b[31merror\u001b[39m  \"name\" must be kebab-case (got \"My Deploy Skill\")  \u001b[2mskill-md/name-kebab-case\u001b[22m\r\n  \u001b[33mwarn \u001b[39m  Body has 3 words (recommended: 500-5000)  \u001b[2mskill-md/body-word-count\u001b[22m\u001b[2m:5\u001b[22m\r\n  \u001b[34minfo \u001b[39m  Body should use H2 (##) sections for organization  \u001b[2mskill-md/body-has-headers\u001b[22m\u001b[2m:5\u001b[22m\r\n\r\n\u001b[4mtests/fixtures/demo-plugin/agents/reviewer.md\u001b[24m\r\n  \u001b[31merror\u001b[39m  \"name\" must be 3-50 chars, lowercase alphanumeric + hyphens (got \"Code Reviewer\")  \u001b[2magent-md/name-format\u001b[22m\r\n  \u001b[31merror\u001b[39m  \"description\" is required in frontmatter  \u001b[2magent-md/description-required\u001b[22m\r\n  \u001b[33mwarn \u001b[39m  \"model\" must be one of: haiku, inherit, opus, sonnet (got \"invalid-model\")  \u001b[2magent-md/model-valid\u001b[22m\r\n\r\n\u001b[4mtests/fixtures/demo-plugin/hooks/hooks.json\u001b[24m\r\n  \u001b[31merror\u001b[39m  Invalid event name \"InvalidEvent\" (valid: ConfigChange, Elicitation, ElicitationResult, InstructionsLoaded, Notification, PermissionRequest, PostToolUse, PostToolUseFailure, PreCompact, PreToolUse, SessionEnd, SessionStart, Setup, Stop, SubagentStart, SubagentStop, TaskCompleted, TeammateIdle, UserPromptSubmit, WorktreeCreate, WorktreeRemove)  \u001b[2mhooks-json/valid-event-names\u001b[22m\u001b[2m:14:5\u001b[22m\r\n\r\n\u001b[4mtests/fixtures/demo-plugin/.claude/settings.local.json\u001b[24m\r\n  \u001b[33mwarn \u001b[39m  \"model\" is a user-level field — it has no effect in project-level settings.local.json  \u001b[2msettings-json/scope-field\u001b[22m\u001b[2m:6:3\u001b[22m\r\n  \u001b[33mwarn \u001b[39m  Unknown top-level field \"unknownField\"  \u001b[2msettings-json/no-unknown-fields\u001b[22m\u001b[2m:7:3\u001b[22m\r\n  \u001b[33mwarn \u001b[39m  \"includeCoAuthoredBy\" is a user-level field — it has no effect in project-level settings.local.json  \u001b[2msettings-json/scope-field\u001b[22m\u001b[2m:8:3\u001b[22m\r\n\r\n\u001b[4mtests/fixtures/demo-plugin/.mcp.json\u001b[24m\r\n  \u001b[34minfo \u001b[39m  Server name \"my server\" should be kebab-case  \u001b[2mmcp-json/server-name-kebab\u001b[22m\u001b[2m:3:5\u001b[22m\r\n\r\n\u001b[31m5 errors\u001b[39m, \u001b[33m6 warnings\u001b[39m, \u001b[34m2 info\u001b[39m\r\n"]
